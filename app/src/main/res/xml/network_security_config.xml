<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Release / production: no cleartext (use HTTPS in release buildConfig). -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
